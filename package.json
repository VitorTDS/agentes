{
  "name": "ai-agent-office",
  "displayName": "AI Agent Office",
  "version": "1.0.0",
  "description": "Escritorio visual pixel art de agentes de IA dentro do VS Code.",
  "publisher": "local",
  "main": "./src/extension.js",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=18"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:aiAgentOffice.openOffice"
  ],
  "contributes": {
    "commands": [
      {
        "command": "aiAgentOffice.openOffice",
        "title": "AI Agent Office: Abrir Escritório"
      }
    ]
  },
  "scripts": {
    "compile": "node --check src/extension.js && node --check media/office.js",
    "test": "npm run compile"
  },
  "keywords": [
    "vscode",
    "extension",
    "webview",
    "pixel-art",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {}
}
